# Todas as variáveis abaixo são opcionais. Sem elas, o app funciona
# normalmente — Sentry e Microsoft Clarity simplesmente não inicializam.

# DSN do projeto Sentry (US-23, ADR-007). Client-side, por isso NEXT_PUBLIC_.
NEXT_PUBLIC_SENTRY_DSN=

# Project ID do Microsoft Clarity (US-24, ADR-011). Só carrega o script após
# consentimento explícito do usuário no banner de cookies.
NEXT_PUBLIC_CLARITY_PROJECT_ID=
